{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-all",
            "type": "process",
            "command": "c++",
            "args": [
                "-std=c++17",
                "-Wall",
                "-Wextra",
                "${workspaceFolder}/CPP_Files/main.cpp",
                "${workspaceFolder}/CPP_Files/captain.cpp",
                "${workspaceFolder}/CPP_Files/hero.cpp",
                "${workspaceFolder}/CPP_Files/menu.cpp",
                "${workspaceFolder}/CPP_Files/team.cpp",
                "${workspaceFolder}/CPP_Files/team_reader.cpp",
                "${workspaceFolder}/CPP_Files/team_system.cpp",
                "${workspaceFolder}/CPP_Files/user_system.cpp",
                "-o",
                "${workspaceFolder}/CPP_Files/app"
            ],
            "windows": {
                "command": "C:\\TDM-GCC-64\\bin\\g++.EXE",
                "args": [
                    "-std=c++17",
                    "-Wall",
                    "-Wextra",
                    "${workspaceFolder}\\CPP_Files\\main.cpp",
                    "${workspaceFolder}\\CPP_Files\\captain.cpp",
                    "${workspaceFolder}\\CPP_Files\\hero.cpp",
                    "${workspaceFolder}\\CPP_Files\\menu.cpp",
                    "${workspaceFolder}\\CPP_Files\\team.cpp",
                    "${workspaceFolder}\\CPP_Files\\team_reader.cpp",
                    "${workspaceFolder}\\CPP_Files\\team_system.cpp",
                    "${workspaceFolder}\\CPP_Files\\user_system.cpp",
                    "-lshell32",
                    "-o",
                    "${workspaceFolder}\\CPP_Files\\app.exe"
                ]
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "type": "cppbuild",
            "label": "C/C++: g++.exe build active file",
            "command": "C:\\TDM-GCC-64\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Task generated by Debugger."
        },
        {
            "type": "cppbuild",
            "label": "C/C++: cl.exe build active file",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/nologo",
                "/Fe${fileDirname}\\${fileBasenameNoExtension}.exe",
                "${file}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Task generated by Debugger."
        }
    ]
}