{
    "version": "2.0.0",
    "configurations": [
        {
            "name": "Debug C++ Project",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/CPP_Files/app",
            "cwd": "${workspaceFolder}/CPP_Files",
            "externalConsole": true,
            "MIMode": "gdb",
            "miDebuggerPath": "gdb",
            "preLaunchTask": "build-all",
            "windows": {
                "program": "${workspaceFolder}\\CPP_Files\\app.exe",
                "cwd": "${workspaceFolder}\\CPP_Files",
                "MIMode": "gdb",
                "miDebuggerPath": "gdb.exe"
            },
            "osx": {
                "program": "${workspaceFolder}/CPP_Files/app",
                "cwd": "${workspaceFolder}/CPP_Files",
                "MIMode": "lldb",
                "miDebuggerPath": "lldb"
            },
            "linux": {
                "program": "${workspaceFolder}/CPP_Files/app",
                "cwd": "${workspaceFolder}/CPP_Files",
                "MIMode": "gdb",
                "miDebuggerPath": "gdb"
            }
        }
    ]
}